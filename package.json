{
  "name": "termopane-app",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test && tsx tests/prisma-schema-invariants.test.ts && tsx tests/smoke-pilot-deployment.test.ts",
    "pilot:acceptance": "pnpm prisma:generate && pnpm db:migrate:deploy && pnpm db:seed && playwright test --config=tests/e2e/playwright.config.ts",
    "reference:validate": "tsx packages/calculation/src/reference-offer-validate.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "verify": "pnpm prisma generate && pnpm check",
    "format": "prettier --write .",
    "prisma": "prisma",
    "prisma:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "env:check-defaults": "tsx scripts/check-production-env-defaults.ts",
    "storage:smoke": "tsx scripts/smoke-document-storage.ts",
    "pilot:smoke": "tsx scripts/smoke-pilot-deployment.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.1"
  },
  "devDependencies": {
    "@playwright/test": "1.51.1",
    "@types/node": "^20",
    "prettier": "latest",
    "prisma": "^6.19.1",
    "tsx": "^4.20.6",
    "typescript": "latest"
  }
}
