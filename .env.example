DATABASE_URL="postgresql://termopane:termopane@localhost:5432/termopane_app?schema=public"

NEXT_PUBLIC_APP_NAME="Termopane App"

# Development auth foundation.
# Use a long random value in real environments.
AUTH_SECRET="replace-with-a-long-random-development-secret"
AUTH_COOKIE_NAME="termopane_session"
AUTH_SESSION_DAYS="7"
# Set to "true" only in local development with synthetic seed users.
AUTH_DEV_LOGIN_ENABLED="false"

# Document storage provider. Defaults to local.
# S3-compatible storage uses the server-side AWS SDK v3 client.
DOCUMENT_STORAGE_PROVIDER="local"

# Local provider: defaults to .local-storage/documents at the repository root.
DOCUMENT_STORAGE_ROOT=""

# S3-compatible provider config. Keep credential values in your secret store.
DOCUMENT_STORAGE_S3_ENDPOINT=""
DOCUMENT_STORAGE_S3_REGION=""
DOCUMENT_STORAGE_S3_BUCKET=""
DOCUMENT_STORAGE_S3_ACCESS_KEY_ID=""
DOCUMENT_STORAGE_S3_SECRET_ACCESS_KEY=""
DOCUMENT_STORAGE_S3_FORCE_PATH_STYLE="true"

# Customer offer email delivery. Defaults to local synthetic logging in development.
# Use EMAIL_PROVIDER="resend" in production/pilot with secrets from the host secret store.
EMAIL_PROVIDER="local"
EMAIL_FROM=""
EMAIL_REPLY_TO=""
RESEND_API_KEY=""
RESEND_API_URL=""

# Optional pilot smoke-test settings.
# BASE_URL enables the deployed /api/health check when running pnpm pilot:smoke.
BASE_URL=""
PILOT_SMOKE_SYNTHETIC_TENANT_ID="seed_tenant_synthetic_termopane"
PILOT_SMOKE_SYNTHETIC_QUOTE_NUMBER="SYN-0001"
