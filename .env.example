DATABASE_URL="postgresql://termopane:termopane@localhost:5432/termopane_app?schema=public"

NEXT_PUBLIC_APP_NAME="Termopane App"

# Development auth foundation.
# Use a long random value in real environments.
AUTH_SECRET="replace-with-a-long-random-development-secret"
AUTH_COOKIE_NAME="termopane_session"
AUTH_SESSION_DAYS="7"
AUTH_DEV_LOGIN_ENABLED="true"

# Optional local development PDF storage override.
# Defaults to .local-storage at the repository root.
DOCUMENT_STORAGE_ROOT=""
