DATABASE_URL="postgresql://termopane:termopane@localhost:5432/termopane_app?schema=public"

NEXT_PUBLIC_APP_NAME="Termopane App"

# Development auth foundation.
# Use a long random value in real environments.
AUTH_SECRET="replace-with-a-long-random-development-secret"
AUTH_COOKIE_NAME="termopane_session"
AUTH_SESSION_DAYS="7"
AUTH_DEV_LOGIN_ENABLED="true"

# Document storage provider. Defaults to local.
# S3-compatible storage is currently a validated deployment stub, not a live adapter.
DOCUMENT_STORAGE_PROVIDER="local"

# Local provider: defaults to .local-storage at the repository root.
DOCUMENT_STORAGE_ROOT=""

# S3-compatible provider stub/config. Fill these only when testing deployment wiring.
DOCUMENT_STORAGE_S3_ENDPOINT=""
DOCUMENT_STORAGE_S3_REGION=""
DOCUMENT_STORAGE_S3_BUCKET=""
DOCUMENT_STORAGE_S3_ACCESS_KEY_ID=""
DOCUMENT_STORAGE_S3_SECRET_ACCESS_KEY=""
DOCUMENT_STORAGE_S3_FORCE_PATH_STYLE="true"
